# This .gitignore file is configured for Vivado projects.
# The goal is to only track user-written source files and ignore all
# files and directories generated by Vivado.

#
# General files to ignore
#
*.log
*.jou
*.str
*.vds
*.dcp
*.rpt
*.pb
*.xpr
*.lpr
*.wdb
*.wdf
*.wpc
*.swp

#
# Generated directories
#
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
xsim.dir/

#
# Vivado-generated scripts
#
rundef.js
runme.bat
runme.sh
ISEWrap.js
ISEWrap.sh
htr.txt
compile.bat
elaborate.bat
simulate.bat

#
# Webtalk usage statistics
#
webtalk*
*.html
# Be careful with this one, it might ignore user-created XML files.
# In this project, all XML files are generated by Vivado.
*.xml

#
# Temporary and binary files
#
__synthesis_is_complete__
__synthesis_is_running__
*.backup.*
*.c
*.obj
*.o
*.dll
*.exe
*.so
*.mem
*.bin
*.sdb
*.reloc
*.rtti
*.svtype
*.type
*.xdbg
*.ini

#
# IP core files
#
*.xci
*.xcix
*.xco
*.coe

#
# Text files
#
# Ignore all .txt files...
*.txt
# ...but keep README files.
!README.md
!readme.md

#
# It is a good practice to have a Tcl script to regenerate the project.
# If you have one, you can un-comment the line below to track it.
# !project_create.tcl
